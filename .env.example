# sa3.cpp configuration — copy to `.env` (loaded from the working dir at startup).
# A real environment variable always overrides what's here, so a downstream app can set these
# directly in the process it spawns and ignore this file entirely. CLI flags override both.

# Where `--model <variant>` resolves the gguf set:
SA3_MODELS_DIR=models

# Where `--lora <name>` resolves lora-<name>-*.gguf (adapters can live anywhere; defaults to SA3_MODELS_DIR):
# SA3_ADAPTERS_DIR=adapters

# Where source .ckpt/.safetensors LoRA exports live before conversion to GGUF:
# SA3_SOURCE_LORAS_DIR=loras

# Where sa3-server reads dice prompt pools (defaults.json plus optional <lora>.json files):
# SA3_PROMPTS_DIR=prompts

# Backend / performance (all optional):
# SA3_DEVICE=cpu              # force CPU even in a GPU build (parity / debugging)
# SA3_GPU=nvidia             # pick a GPU by 0-based index or name substring (multi-GPU machines)
# SA3_THREADS=8              # CPU backend thread count (also available as --threads on CLI/server)
# SA3_FLASH_ATTN=1           # fused flash attention — faster decode (see docs/BENCHMARKS.md)
# SA3_SAME_FLASH_ATTN=full   # SAME-L decoder flash: full | local | 0   (use full; local is Metal-only)

# Server request defaults:
SA3_DEFAULT_DURATION=30
SA3_MAX_DURATION=300
SA3_DEFAULT_LOOP_BARS=8
SA3_LOOP_PAD_SECONDS=2.0

# Loudness safety (defaults mirror gary4local; set empty/off/none/false to disable optional stages):
SA3_PEAK_NORMALIZE_DB=2.0
SA3_LIMITER_CEILING_DB=-0.3
SA3_LIMITER_KNEE=0.8

# Optional latent experiments (normally leave these alone):
SA3_LATENT_RESCALE=1.0
SA3_LATENT_SHIFT=0.0
# SA3_LATENT_TARGET_STD=
# SA3_LATENT_ADAPT_MIN=0.9
# SA3_LATENT_ADAPT_MAX=1.0
